DEBUG=True
SECRET_KEY=your-secret-key-here

# SOP's own Postgres
DATABASE_URL=postgres://sop:sop@localhost:5432/sop

# Shared Redis (same instance as existing scraper)
REDIS_URL=redis://localhost:6379/0

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=sop

# Existing Node.js backend
EXISTING_BACKEND_URL=http://localhost:3000
SOP_WEBHOOK_URL=http://localhost:8000/api/v1/webhook/receive

# Cache TTL seconds
CACHE_TTL_INSTAGRAM=86400