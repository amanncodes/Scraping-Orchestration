DEBUG=True
SECRET_KEY=super-secret-key-change-in-prod

DATABASE_URL=postgres://sop:sop@postgres:5432/sop

REDIS_URL=redis://redis:6379/0

MONGO_URL=mongodb://mongo:27017
MONGO_DB=sop

# Your office scraper — replace with actual IP/URL
SCRAPER_URL=http://YOUR_OFFICE_PC_IP:PORT

# SOP's own public webhook URL (your machine must be reachable by the scraper)
# Use ngrok if scraper needs to call back: ngrok http 8000
SOP_WEBHOOK_URL=http://YOUR_LOCAL_IP:8000/api/v1/webhook/receive

CACHE_TTL_INSTAGRAM=86400